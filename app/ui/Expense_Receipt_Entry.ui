/* =========================
   BASE
   ========================= */
QWidget {
    background-color: #121212;
    color: #EAEAEA;
    font-family: &quot;Segoe UI&quot;;
    font-size: 13px;
}
/* =========================
   HEADER
   ========================= */
QFrame#headerBar {
    background-color: #171717;
    border-bottom: 1px solid rgba(255,255,255,10);
}
QLabel {
    background-color: #171717;
}

QLabel#lblTitle {
    color: #FF9800;
    font-size: 22px;
    font-weight: 800;
}

QLabel#lblSubtitle {
    color: rgba(255,255,255,150);
    font-size: 12px;
}

/* =========================
   CARD
   ========================= */
QFrame#contentCard {
    background-color: #171717;
    border: 1px solid rgba(255,255,255,10);
    border-radius: 18px;
}

/* Divider */
QFrame#divider {
    background-color: rgba(255,255,255,10);
}

/* =========================
   LABELS
   ========================= */
QLabel.formLabel {
    color: rgba(255,255,255,200);
    font-weight: 600;
}

/* =========================
   INPUTS (consistent)
   ========================= */
QLineEdit, QComboBox, QDateEdit, QTextEdit {
    background-color: transparent;
    color: #FFFFFF;
    border: 1.5px solid #FF9800;
    border-radius: 10px;
    padding: 8px 10px;
}

QLineEdit, QComboBox, QDateEdit {
    min-height: 38px;
}

QTextEdit {
    padding: 10px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus, QTextEdit:focus {
    border: 2px solid #FFA726;
}

/* Combo dropdown */
QComboBox::drop-down {
    border: none;
    width: 28px;
}
QComboBox::down-arrow {
    width: 10px;
    height: 10px;
}

/* DateEdit arrow/popup */
QDateEdit::drop-down {
    border: none;
    width: 28px;
}

/* =========================
   ATTACHMENT PREVIEW
   ========================= */
QLabel#lblSelectPicture {
    border: 1px dashed rgba(255,152,0,120);
    border-radius: 14px;
    color: rgba(255,255,255,170);
    background-color: rgba(255,255,255,4);
}

/* =========================
   BUTTONS
   ========================= */
QPushButton {
    background-color: transparent;
    color: #FF9800;
    font-weight: bold;
    border: 2px solid #FF9800;
    border-radius: 12px;
    padding: 10px 14px;
    min-height: 40px;
}

QPushButton:hover {
    background-color: rgba(255, 152, 0, 25);
}

QPushButton:pressed {
    background-color: rgba(255, 152, 0, 60);
    color: black;
}

/* Primary action button */
QPushButton#btnSave {
    background-color: #FF9800;
    color: #111111;
    border: none;
    font-weight: 800;
}

QPushButton#btnSave:hover {
    background-color: #FFA726;
}

QPushButton#btnSave:pressed {
    background-color: #F57C00;
}

/* Secondary button (optional) */
QPushButton#btnCancel {
    border-color: rgba(255,255,255,22);
    color: rgba(255,255,255,200);
}
QPushButton#btnCancel:hover {
    background-color: rgba(255,255,255,6);
}

/* Disabled */
QPushButton:disabled {
    border-color: #555;
    color: #555;
}

/* =========================
   BACK BUTTON (creative)
   ========================= */
QToolButton#btnBack {
    background-color: rgba(255, 152, 0, 10);
    color: #FF9800;
    border: 1.5px solid rgba(255, 152, 0, 140);
    border-radius: 22px;              /* circular (44px button) */
    font-size: 18px;
    font-weight: 900;
}

QToolButton#btnBack:hover {
    background-color: rgba(255, 152, 0, 22);
    border: 2px solid #FFA726;
}

QToolButton#btnBack:pressed {
    background-color: rgba(255, 152, 0, 55);
    color: #111111;
}
