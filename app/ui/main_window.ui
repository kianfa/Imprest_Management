/* =========================
   BASE
   ========================= */
QDialog {
    background-color: #0F1115;
    color: #EAEAEA;
    font-family: &quot;Segoe UI&quot;;
    font-size: 13px;
}

/* =========================
   PANELS
   ========================= */
QFrame#leftPanel {
    background-color: #0F1115;
}

QFrame#rightPanel {
    background-color: #141824;
    border-left: 1px solid rgba(255, 255, 255, 14);
}

/* =========================
   TEXT STYLES
   ========================= */
QLabel {
    color: rgba(255, 255, 255, 210);
}

QLabel#lblBrand {
    color: #FFFFFF;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 0.3px;
}

QLabel#lblTagline {
    color: rgba(255, 255, 255, 160);
    font-size: 14px;
}

QLabel#lblTitle {
    color: #FFFFFF;
    font-size: 26px;
    font-weight: 800;
}

QLabel#lblSubtitle {
    color: rgba(255, 255, 255, 150);
    font-size: 13px;
}

QLabel#lblHint {
    color: rgba(255, 255, 255, 140);
    font-size: 12px;
}

QLabel#lblFooter {
    color: rgba(255, 255, 255, 110);
    font-size: 11px;
}

/* =========================
   INPUTS
   ========================= */
QLineEdit {
    background-color: rgba(255, 255, 255, 6);
    border: 1px solid rgba(255, 255, 255, 18);
    border-radius: 12px;
    padding: 12px 14px;
    color: #FFFFFF;
    min-height: 44px;
    selection-background-color: rgba(255, 152, 0, 110);
}

QLineEdit:hover {
    border: 1px solid rgba(255, 255, 255, 28);
}

QLineEdit:focus {
    border: 2px solid #FF9800;
    background-color: rgba(255, 255, 255, 8);
}

QLineEdit::placeholder {
    color: rgba(255, 255, 255, 110);
}

/* =========================
   PRIMARY BUTTON
   ========================= */
QPushButton#btnLogin {
    background-color: #FF9800;
    color: #101114;
    border: none;
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 800;
    min-height: 46px;
}

QPushButton#btnLogin:hover {
    background-color: #FFA726;
}

QPushButton#btnLogin:pressed {
    background-color: #F57C00;
}

/* =========================
   CHECKBOX
   ========================= */
QCheckBox {
    color: rgba(255, 255, 255, 170);
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
}

QCheckBox::indicator:unchecked {
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 26);
    background-color: rgba(255, 255, 255, 6);
}

QCheckBox::indicator:checked {
    border-radius: 6px;
    border: 1px solid #FF9800;
    background-color: #FF9800;
}

/* =========================
   OPTIONAL: subtle divider line
   ========================= */
QFrame#divider {
    background-color: rgba(255,255,255,10);
}
