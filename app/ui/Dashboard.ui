  <property name="styleSheet">
   <string notr="true">
/* =========================
   BASE
   ========================= */
QMainWindow, QWidget {
    background-color: #121212;
    color: #EAEAEA;
    font-family: "Segoe UI";
    font-size: 13px;
}

/* =========================
   HEADER BAR
   ========================= */
QFrame#headerBar {
    background-color: #151515;
    border-bottom: 1px solid rgba(255,255,255,10);
}

/* Titles */
QLabel#lblTitle {
    color: #FF9800;
    font-size: 24px;
    font-weight: 800;
}

QLabel#lblSubtitle {
    color: rgba(255,255,255,160);
    font-size: 13px;
}

/* =========================
   CONTENT CARD
   ========================= */
QFrame#contentCard {
    background-color: #171717;
    border: 1px solid rgba(255,255,255,10);
    border-radius: 18px;
}

/* Section heading */
QLabel#lblSection {
    color: rgba(255,255,255,220);
    font-size: 16px;
    font-weight: 700;
}

/* Hint text */
QLabel#lblHint {
    color: rgba(255,255,255,140);
    font-size: 12px;
}

/* Divider */
QFrame#divider {
    background-color: rgba(255,255,255,10);
}

/* =========================
   ACTION TILES (Buttons)
   ========================= */
QPushButton.actionTile {
    background-color: rgba(255,255,255,6);
    color: #FFFFFF;
    border: 1px solid rgba(255,255,255,12);
    border-radius: 16px;
    padding: 18px;
    font-size: 15px;
    font-weight: 800;
    text-align: left;
    min-height: 140px;
}

QPushButton.actionTile:hover {
    border: 1px solid rgba(255,152,0,55);
    background-color: rgba(255,152,0,10);
}

QPushButton.actionTile:pressed {
    background-color: rgba(255,152,0,18);
    border: 1px solid rgba(255,152,0,90);
}

/* Optional: make the "primary" tile slightly more orange */
QPushButton#btndashboard_input {
    border: 1px solid rgba(255,152,0,45);
}

/* =========================
   STANDARD BUTTONS (if you add more later)
   ========================= */
QPushButton {
    background-color: transparent;
    color: #FF9800;
    font-weight: bold;
    border: 2px solid #FF9800;
    border-radius: 10px;
    padding: 10px 14px;
}

QPushButton:hover {
    background-color: rgba(255, 152, 0, 25);
}

QPushButton:pressed {
    background-color: rgba(255, 152, 0, 60);
    color: black;
}

/* =========================
   MENUBAR / STATUSBAR
   ========================= */
QMenuBar {
    background-color: #151515;
    color: rgba(255,255,255,200);
    border-bottom: 1px solid rgba(255,255,255,10);
}

QStatusBar {
    background-color: #151515;
    color: rgba(255,255,255,160);
    border-top: 1px solid rgba(255,255,255,10);
}

/* Toolbar */
QToolBar {
    background-color: #151515;
    border-bottom: 1px solid rgba(255,255,255,10);
}
   </string>
