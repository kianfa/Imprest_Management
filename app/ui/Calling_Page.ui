   <string notr="true">
/* ===== Base ===== */
QWidget {
    background-color: #191919;
    color: #EAEAEA;
    font-family: "Segoe UI";
    font-size: 13px;
}

QLabel {
    color: #EAEAEA;
}

/* ===== GroupBox (card) ===== */
QGroupBox {
    background-color: #161616;
    border: 1px solid #2A2A2A;
    border-radius: 10px;
    margin-top: 14px;
    padding: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 6px;
    color: #EAEAEA;
    font-weight: bold;
}

/* ===== Inputs ===== */
QLineEdit, QComboBox, QDateEdit {
    background-color: #1C1C1C;
    color: #FFFFFF;
    border: 1px solid #3A3A3A;
    border-radius: 8px;
    padding: 6px 10px;
    min-height: 34px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 2px solid #FF9800;
}

/* ===== ComboBox dropdown button ===== */
QComboBox {
    padding-right: 30px;
}

QComboBox::drop-down {
    width: 26px;
    border-left: 1px solid #3A3A3A;
    background-color: #1C1C1C;
}

QComboBox::drop-down:hover {
    background-color: #232323;
}

/* ===== DateEdit calendar button ===== */
QDateEdit {
    padding-right: 30px;
}

QDateEdit::drop-down {
    width: 26px;
    border-left: 1px solid #3A3A3A;
    background-color: #FF9800;   /* calendar button color */
}

QDateEdit::drop-down:hover {
    background-color: #FFA726;
}

QDateEdit::drop-down:pressed {
    background-color: #F57C00;
}

/* ===== Calendar popup ===== */
QCalendarWidget {
    background-color: #151515;
    color: #EAEAEA;
    border: 1px solid #FF9800;
}

QCalendarWidget QToolButton {
    color: #FFFFFF;
    background-color: transparent;
    border: none;
    padding: 6px;
}

QCalendarWidget QToolButton:hover {
    background-color: #232323;
}

QCalendarWidget QAbstractItemView {
    background-color: #141414;
    color: #EAEAEA;
    selection-background-color: #FF9800;
    selection-color: #111111;
}

/* ===== RadioButton ===== */
QRadioButton {
    color: #EAEAEA;
    padding: 6px 4px;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QRadioButton::indicator:unchecked {
    border: 2px solid #3A3A3A;
    background-color: #1C1C1C;
    border-radius: 8px;
}

QRadioButton::indicator:checked {
    border: 2px solid #FF9800;
    background-color: #FF9800;
    border-radius: 8px;
}

/* ===== Buttons ===== */
QPushButton {
    background-color: transparent;
    color: #FF9800;
    font-weight: bold;
    border: 2px solid #FF9800;
    border-radius: 10px;
    padding: 10px 14px;
    min-height: 40px;
}

QPushButton:hover {
    background-color: #232323;
}

QPushButton:pressed {
    background-color: #2B2B2B;
}

/* Primary (Search) */
QPushButton#btnSearch {
    background-color: #FF9800;
    color: #111111;
    border: none;
}

QPushButton#btnSearch:hover { background-color: #FFA726; }
QPushButton#btnSearch:pressed { background-color: #F57C00; }

/* Secondary */
QPushButton#btnSaveasexcel {
    color: #EAEAEA;
    border: 1px solid #3A3A3A;
}

QPushButton#btnSaveasexcel:hover {
    background-color: #232323;
}

/* Disabled */
QPushButton:disabled {
    color: #777777;
    border-color: #444444;
}

/* ===== Table ===== */
QTableView {
    background-color: #111827;
    alternate-background-color: #0B1220;
    color: #E5E7EB;
    gridline-color: #1F2937;
    border: 1px solid #1F2937;
    border-radius: 8px;
    selection-background-color: #FF9800;
    selection-color: #111111;
}

QHeaderView::section {
    background-color: #0F172A;
    color: #E5E7EB;
    padding: 8px 10px;
    border: none;
    border-right: 1px solid #1F2937;
    font-weight: bold;
}
